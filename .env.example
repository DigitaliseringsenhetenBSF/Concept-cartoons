# Kopiera till .env och fyll i EN av nycklarna. .env får ALDRIG checkas in.
# Nyckeln används endast av servern (server/index.ts) – aldrig i webbläsarkod.
# Finns båda nycklarna används OpenAI.

# OpenAI (nyckel från platform.openai.com, börjar med sk-proj- eller sk-)
OPENAI_API_KEY=
# Valfritt: OpenAI-modell (standard gpt-5-mini)
OPENAI_MODEL=

# Anthropic (nyckel från platform.claude.com, börjar med sk-ant-)
ANTHROPIC_API_KEY=

# Valfritt: port för API-servern (standard 3001)
API_PORT=3001
