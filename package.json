{
  "name": "diskussionsunderlag",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Diskussionsunderlag – Concept Cartoons-generator för Barn- och skolförvaltningen, Lunds kommun",
  "scripts": {
    "dev": "concurrently -n vite,api -c blue,magenta \"vite\" \"tsx watch server/index.ts\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "vitest run src/smoke.test.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jspdf": "^2.5.2",
    "pptxgenjs": "^3.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "eslint": "^9.9.0",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.2.0",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
